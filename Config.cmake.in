@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(EGLRENDER_NATIVE_DISPLAY "@EGLRENDER_NATIVE_DISPLAY@" )
set(EGLRENDER_LIBS "@EGLRENDER_LIBS@" )

find_dependency(OpenGL COMPONENTS EGL)
if(EGLRENDER_NATIVE_DISPLAY STREQUAL "X11")
  find_dependency(X11)
endif()

set(EGLRENDER_GPU_COMPUTE_API "@EGLRENDER_GPU_COMPUTE_API@")
if(EGLRENDER_GPU_COMPUTE_API STREQUAL "CUDA")
  find_dependency(CUDAToolkit REQUIRED)
elseif(EGLRENDER_GPU_COMPUTE_API STREQUAL "HIP")
  find_dependency(ROCmCMakeBuildTools REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/EGLRenderTargets.cmake")
check_required_components(EGLRender)

